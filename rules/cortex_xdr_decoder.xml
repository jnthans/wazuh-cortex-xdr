<!--
  Wazuh Custom Decoder - Cortex XDR Integration
  ===============================================
  File: /var/ossec/etc/decoders/cortex_xdr_decoder.xml

  Wodle command output arrives as raw JSON lines on stdout with no syslog
  wrapper or program_name.  Wazuh's built-in JSON decoder handles the
  parsing; this decoder anchors the prematch so rules can identify
  Cortex XDR events via the integration field.

  Verify with: /var/ossec/bin/wazuh-logtest
  Apply with:  systemctl restart wazuh-manager
-->

<decoder name="cortex_xdr">
  <prematch>{"integration":"cortex_xdr"</prematch>
  <plugin_decoder>JSON_Decoder</plugin_decoder>
</decoder>
