<!--
  Wazuh Custom Rules – Cortex XDR Integration
  =============================================
  File: /var/ossec/etc/rules/cortex_xdr_rules.xml
  Rule ID range: 100500–100599

  DESIGN NOTES
  ─────────────────────────────────────────────────────────────────────────────
  Field naming: all Cortex XDR API fields are prefixed with 'xdr_' to avoid
  collisions with Wazuh's 13 reserved static field names (action, status,
  id, user, srcip, dstip, srcport, dstport, protocol, url, data,
  extra_data, system_name).

  Three data streams, three rule families:
    100500        Base rule (all XDR events)
    100510–100529 Alert rules    (raw detections from endpoint/cloud sensors)
    100530–100549 Active incident rules  (new + under_investigation)
    100550–100569 Closed incident rules  (resolved — archival/closure records)
    100570–100589 MITRE ATT&CK cross-references (populated from incident data)
    100599        Error rule

  Severity → Wazuh level mapping:
    low      → 5   (informational)
    medium   → 10  (significant)
    high     → 13  (high priority)
    critical → 15  (maximum)

  Compliance tags on high/critical rules:
    gdpr_IV_35.7.d, hipaa_164.312.b, nist_800_53_SI.4,
    pci_dss_11.4, tsc_CC7.2

  Verify: /var/ossec/bin/wazuh-logtest
  Apply:  systemctl restart wazuh-manager
-->

<group name="cortex-xdr,">

  <!-- ════════════════════════════════════════════════════════════
       BASE RULE
       Catches all Cortex XDR wodle output. All other rules
       chain from this via if_sid.
       ════════════════════════════════════════════════════════ -->

  <rule id="100500" level="3">
    <decoded_as>json</decoded_as>
    <field name="integration">cortex-xdr</field>
    <description>Cortex XDR: event received</description>
    <options>no_full_log</options>
    <group>cortex_xdr,</group>
  </rule>


  <!-- ════════════════════════════════════════════════════════════
       ALERT RULES  (100510–100529)
       Raw detections from Cortex endpoint and cloud sensors.
       Default ingestion: high + critical, DETECTED action only.
       ════════════════════════════════════════════════════════ -->

  <rule id="100510" level="5">
    <if_sid>100500</if_sid>
    <field name="type">alert</field>
    <description>Cortex XDR Alert: $(xdr_alert_name)</description>
    <group>cortex_xdr,cortex_xdr_alert,</group>
  </rule>

  <rule id="100511" level="5">
    <if_sid>100510</if_sid>
    <field name="xdr_severity">low</field>
    <description>Cortex XDR Alert [LOW]: $(xdr_alert_name) on $(xdr_agent_hostname)</description>
    <group>cortex_xdr,cortex_xdr_alert,low_severity,</group>
  </rule>

  <rule id="100512" level="9">
    <if_sid>100510</if_sid>
    <field name="xdr_severity">medium</field>
    <description>Cortex XDR Alert [MEDIUM]: $(xdr_alert_name) on $(xdr_agent_hostname)</description>
    <group>cortex_xdr,cortex_xdr_alert,medium_severity,</group>
  </rule>

  <rule id="100513" level="12">
    <if_sid>100510</if_sid>
    <field name="xdr_severity">high</field>
    <description>Cortex XDR Alert [HIGH]: $(xdr_alert_name) on $(xdr_agent_hostname)</description>
    <group>cortex_xdr,cortex_xdr_alert,high_severity,
           gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_SI.4,pci_dss_11.4,tsc_CC7.2,</group>
  </rule>

  <rule id="100514" level="15">
    <if_sid>100510</if_sid>
    <field name="xdr_severity">critical</field>
    <description>Cortex XDR Alert [CRITICAL]: $(xdr_alert_name) on $(xdr_agent_hostname)</description>
    <group>cortex_xdr,cortex_xdr_alert,critical_severity,
           gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_SI.4,pci_dss_11.4,tsc_CC7.2,</group>
  </rule>

  <rule id="100515" level="13">
    <if_sid>100510</if_sid>
    <field name="xdr_category">Malware</field>
    <description>Cortex XDR Malware Alert: $(xdr_alert_name) on $(xdr_agent_hostname)</description>
    <group>cortex_xdr,cortex_xdr_alert,malware,rootcheck,</group>
  </rule>

  <!-- BLOCKED = Cortex automatically stopped the threat -->
  <rule id="100516" level="6">
    <if_sid>100510</if_sid>
    <field name="xdr_action">BLOCKED</field>
    <description>Cortex XDR: Threat blocked by prevention policy on $(xdr_agent_hostname): $(xdr_alert_name)</description>
    <group>cortex_xdr,cortex_xdr_alert,blocked,</group>
  </rule>

  <!-- DETECTED = threat seen but not stopped — highest priority alert action -->
  <rule id="100517" level="12">
    <if_sid>100510</if_sid>
    <field name="xdr_action">DETECTED</field>
    <description>Cortex XDR: Threat DETECTED but not blocked on $(xdr_agent_hostname): $(xdr_alert_name)</description>
    <group>cortex_xdr,cortex_xdr_alert,detected_unblocked,
           gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_SI.4,pci_dss_11.4,</group>
  </rule>

  <rule id="100518" level="8">
    <if_sid>100510</if_sid>
    <field name="xdr_alert_source">XDR Analytics</field>
    <description>Cortex XDR Behavioral Analytics Alert: $(xdr_alert_name)</description>
    <group>cortex_xdr,cortex_xdr_alert,behavioral,</group>
  </rule>

  <rule id="100519" level="9">
    <if_sid>100510</if_sid>
    <field name="xdr_alert_source">XDR Analytics BIOC</field>
    <description>Cortex XDR BIOC (Cloud/Identity) Alert: $(xdr_alert_name)</description>
    <group>cortex_xdr,cortex_xdr_alert,bioc,</group>
  </rule>

  <rule id="100520" level="9">
    <if_sid>100510</if_sid>
    <field name="xdr_alert_source">Correlation</field>
    <description>Cortex XDR Correlation Rule Alert: $(xdr_alert_name)</description>
    <group>cortex_xdr,cortex_xdr_alert,correlation,</group>
  </rule>


  <!-- ════════════════════════════════════════════════════════════
       ACTIVE INCIDENT RULES  (100530–100549)
       new + under_investigation — real-time SOC alerting.
       Polled every 5 minutes.
       ════════════════════════════════════════════════════════ -->

  <rule id="100530" level="6">
    <if_sid>100500</if_sid>
    <field name="type">incident</field>
    <description>Cortex XDR Incident: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,</group>
  </rule>

  <rule id="100531" level="6">
    <if_sid>100530</if_sid>
    <field name="xdr_severity">low</field>
    <field name="xdr_status">new|under_investigation</field>
    <description>Cortex XDR Incident [LOW]: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,low_severity,</group>
  </rule>

  <rule id="100532" level="10">
    <if_sid>100530</if_sid>
    <field name="xdr_severity">medium</field>
    <field name="xdr_status">new|under_investigation</field>
    <description>Cortex XDR Incident [MEDIUM]: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,medium_severity,</group>
  </rule>

  <rule id="100533" level="13">
    <if_sid>100530</if_sid>
    <field name="xdr_severity">high</field>
    <field name="xdr_status">new|under_investigation</field>
    <description>Cortex XDR Incident [HIGH]: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,high_severity,
           gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_SI.4,pci_dss_11.4,</group>
  </rule>

  <rule id="100534" level="15">
    <if_sid>100530</if_sid>
    <field name="xdr_severity">critical</field>
    <field name="xdr_status">new|under_investigation</field>
    <description>Cortex XDR Incident [CRITICAL]: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,critical_severity,
           gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_SI.4,pci_dss_11.4,tsc_CC7.2,</group>
  </rule>

  <!-- Incident actively being worked by an analyst -->
  <rule id="100535" level="6">
    <if_sid>100530</if_sid>
    <field name="xdr_status">under_investigation</field>
    <description>Cortex XDR Incident under investigation by $(xdr_assigned_user_pretty_name): $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,investigation,</group>
  </rule>

  <!-- Large correlated incident — many alerts grouped together -->
  <rule id="100538" level="11">
    <if_sid>100530</if_sid>
    <field name="xdr_alert_count">\d{2,}</field>
    <field name="xdr_status">new|under_investigation</field>
    <description>Cortex XDR Incident with $(xdr_alert_count) correlated alerts: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,correlated,</group>
  </rule>


  <!-- ════════════════════════════════════════════════════════════
       CLOSED INCIDENT RULES  (100550–100569)
       resolved_true_positive + resolved_false_positive
       Archival records and closure visibility for SOC.
       Polled every 30 minutes. Level 3 — informational only.
       ════════════════════════════════════════════════════════ -->

  <rule id="100550" level="3">
    <if_sid>100530</if_sid>
    <field name="xdr_status">resolved_true_positive</field>
    <description>Cortex XDR Incident closed as TRUE POSITIVE: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,closed,true_positive,</group>
  </rule>

  <rule id="100551" level="3">
    <if_sid>100530</if_sid>
    <field name="xdr_status">resolved_false_positive</field>
    <description>Cortex XDR Incident closed as FALSE POSITIVE: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,closed,false_positive,</group>
  </rule>

  <!-- True positive closed with analyst comment — highest signal for threat hunting -->
  <rule id="100552" level="5">
    <if_sid>100550</if_sid>
    <field name="xdr_resolve_comment">\.+</field>
    <description>Cortex XDR TRUE POSITIVE closed with analyst note: $(xdr_resolve_comment)</description>
    <group>cortex_xdr,cortex_xdr_incident,closed,true_positive,analyst_note,</group>
  </rule>

  <!-- High/critical true positives are significant even when closed -->
  <rule id="100553" level="8">
    <if_sid>100550</if_sid>
    <field name="xdr_severity">high</field>
    <description>Cortex XDR HIGH severity incident closed as true positive: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,closed,true_positive,high_severity,
           gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_IR.4,pci_dss_12.10,</group>
  </rule>

  <rule id="100554" level="10">
    <if_sid>100550</if_sid>
    <field name="xdr_severity">critical</field>
    <description>Cortex XDR CRITICAL severity incident closed as true positive: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,closed,true_positive,critical_severity,
           gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_IR.4,pci_dss_12.10,tsc_CC7.2,</group>
  </rule>


  <!-- ════════════════════════════════════════════════════════════
       MITRE ATT&CK RULES  (100570–100589)
       Cross-reference incidents with MITRE tactics.
       These fire IN ADDITION TO the severity rules above,
       populating Wazuh's native MITRE ATT&CK dashboard.
       ════════════════════════════════════════════════════════ -->

  <rule id="100570" level="6">
    <if_sid>100530</if_sid>
    <field name="xdr_mitre_tactics_ids_and_names">\.+</field>
    <description>Cortex XDR Incident with MITRE ATT&amp;CK mapping: $(xdr_description)</description>
    <!-- No <mitre><id> here — the field contains a full tactic label string
         (e.g. "Persistence - TA0003"), not a bare ID. The specific tactic rules
         below (100571–100578) each match on the label text and hardcode the
         correct MITRE ID, which is what Wazuh's MITRE module indexes. -->
    <group>cortex_xdr,cortex_xdr_incident,mitre_mapped,</group>
  </rule>

  <!-- Persistence — attackers establishing long-term access -->
  <rule id="100571" level="10">
    <if_sid>100570</if_sid>
    <field name="xdr_mitre_tactics_ids_and_names">Persistence</field>
    <description>Cortex XDR MITRE Persistence tactic detected: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,mitre_mapped,mitre_persistence,
           gdpr_IV_35.7.d,nist_800_53_SI.4,</group>
  </rule>

  <!-- Privilege Escalation -->
  <rule id="100572" level="11">
    <if_sid>100570</if_sid>
    <field name="xdr_mitre_tactics_ids_and_names">Privilege Escalation</field>
    <description>Cortex XDR MITRE Privilege Escalation detected: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,mitre_mapped,mitre_privilege_escalation,
           gdpr_IV_35.7.d,hipaa_164.312.a,nist_800_53_AC.6,pci_dss_7.1,</group>
  </rule>

  <!-- Defense Evasion -->
  <rule id="100573" level="11">
    <if_sid>100570</if_sid>
    <field name="xdr_mitre_tactics_ids_and_names">Defense Evasion</field>
    <description>Cortex XDR MITRE Defense Evasion detected: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,mitre_mapped,mitre_defense_evasion,
           nist_800_53_SI.4,pci_dss_11.4,</group>
  </rule>

  <!-- Credential Access -->
  <rule id="100574" level="12">
    <if_sid>100570</if_sid>
    <field name="xdr_mitre_tactics_ids_and_names">Credential Access</field>
    <description>Cortex XDR MITRE Credential Access detected: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,mitre_mapped,mitre_credential_access,
           gdpr_IV_35.7.d,hipaa_164.312.a,nist_800_53_IA.5,pci_dss_8.3,</group>
  </rule>

  <!-- Lateral Movement -->
  <rule id="100575" level="12">
    <if_sid>100570</if_sid>
    <field name="xdr_mitre_tactics_ids_and_names">Lateral Movement</field>
    <description>Cortex XDR MITRE Lateral Movement detected: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,mitre_mapped,mitre_lateral_movement,
           gdpr_IV_35.7.d,nist_800_53_SI.4,pci_dss_11.4,</group>
  </rule>

  <!-- Exfiltration -->
  <rule id="100576" level="13">
    <if_sid>100570</if_sid>
    <field name="xdr_mitre_tactics_ids_and_names">Exfiltration</field>
    <description>Cortex XDR MITRE Exfiltration detected: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,mitre_mapped,mitre_exfiltration,
           gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_SI.4,pci_dss_12.3,</group>
  </rule>

  <!-- Command and Control -->
  <rule id="100577" level="13">
    <if_sid>100570</if_sid>
    <field name="xdr_mitre_tactics_ids_and_names">Command and Control</field>
    <description>Cortex XDR MITRE Command and Control detected: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,mitre_mapped,mitre_c2,
           gdpr_IV_35.7.d,nist_800_53_SI.4,pci_dss_11.4,</group>
  </rule>

  <!-- Impact -->
  <rule id="100578" level="14">
    <if_sid>100570</if_sid>
    <field name="xdr_mitre_tactics_ids_and_names">Impact</field>
    <description>Cortex XDR MITRE Impact detected: $(xdr_description)</description>
    <group>cortex_xdr,cortex_xdr_incident,mitre_mapped,mitre_impact,
           gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_CP.2,pci_dss_12.3,tsc_CC7.2,</group>
  </rule>


  <!-- ════════════════════════════════════════════════════════════
       ERROR RULE
       ════════════════════════════════════════════════════════ -->

  <rule id="100599" level="5">
    <if_sid>100500</if_sid>
    <field name="type">error</field>
    <description>Cortex XDR wodle error: $(xdr_error)</description>
    <group>cortex_xdr,cortex_xdr_error,</group>
  </rule>

</group>