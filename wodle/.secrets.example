# Cortex XDR sensitive configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .secrets and fill in your values:
#   cp .secrets.example .secrets
#   chmod 640 .secrets
#   chown root:wazuh .secrets
#
# .secrets is excluded from git via .gitignore — never commit this file.
# Lines starting with # and blank lines are ignored by the wodle.
# ─────────────────────────────────────────────────────────────────────────────

# Bare hostname only — no https://, no api- prefix, no trailing slash.
XDR_FQDN=yourorg.xdr.us.paloaltonetworks.com

XDR_API_KEY=your-api-key-secret-here
XDR_API_KEY_ID=your-numeric-key-id-here
